# API Keys (Requeridas)
VT_API_KEY=tu_api_key_de_virustotal_aqui
OPENAI_API_KEY=tu_api_key_de_openai_aqui
ADMIN_SECRET_KEY=tu_clave_secreta_de_admin_aqui

# API Keys (Opcionales)
ABUSEIPDB_API_KEY=tu_api_key_de_abuseipdb_aqui

# Caché en Producción (Opcional - Automáticamente cae a SQLite si está vacía)
# Ejemplo: rediss://default:xxxxxx@upstash.io:6379
REDIS_URL=

# Configuración de Seguridad
# Lista de dominios permitidos para CORS. Separa por comas.
# Ejemplo: http://localhost:3000,https://tu-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Entorno
ENVIRONMENT=development
